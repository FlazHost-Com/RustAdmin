# RustAdmin environment (read only via src/config/env.rs)

NODE_ENV=development

# App
APP_NAME=RustAdmin
APP_MODE=full           # full (UI+API) | api
# Rocket binds ROCKET_PORT (default 8000)
# ROCKET_PORT=8000

# Database — dev default is sqlite (file auto-created); no server needed
DB_TYPE=sqlite          # sqlite | mysql | postgres
DB_DATABASE=rust_admin.sqlite
# For mysql/postgres, set parts or a full DATABASE_URL:
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/rustadmin
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=
# DB_DATABASE=rustadmin

# Secrets — REQUIRED in production (app refuses to start with empty values)
SESSION_SECRET=
JWT_SECRET=
JWT_EXPIRES_IN=1h
BCRYPT_ROUNDS=10
OTP_EXPIRY_MINUTES=10

# Optional
REDIS_URL=redis://127.0.0.1:6379
# MAIL_HOST=, MAIL_PORT=587, MAIL_USERNAME=, MAIL_PASSWORD=, MAIL_FROM_NAME=, MAIL_FROM_ADDRESS=
# OSS_ACCESS_ID=, OSS_ACCESS_KEY=, OSS_ENDPOINT=, OSS_BUCKET=, OSS_SSL=true
